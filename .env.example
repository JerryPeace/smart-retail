# ===================================================================
# Marketing Cleaner POC - .env.example
# 複製成 .env.local 後填入實際值。.env.local 不會 commit。
# ===================================================================

# === Application ===
PORT=8000
ENVIRONMENT=dev
LOG_LEVEL=INFO

# === Database (host machine 連 docker postgres 用) ===
DATABASE_USERNAME=poc
DATABASE_PASSWORD=poc
DATABASE_NAME=marketing_cleaner
DATABASE_URL=postgresql+asyncpg://poc:poc@localhost:5434/marketing_cleaner

# === Redis (預留,POC 階段不用 worker)===
REDIS_PASSWORD=redispoc
REDIS_URL=redis://:redispoc@localhost:6380

# === AWS LocalStack (host 連用)===
AWS_ENDPOINT_URL_S3=http://localhost:4567
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
S3_RAW_BUCKET=raw-data
S3_CLEANED_BUCKET=cleaned-data

# === Bedrock (lab 環境權限下來才填)===
# AWS_BEARER_TOKEN_BEDROCK=bedrock_xxxxxxxxxxxxxxxxxxxxxxxx
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5
BEDROCK_REGION=us-east-1

# === HubSpot (Phase 2 才需要)===
# HUBSPOT_API_KEY=pat-xxxxx

# === LangSmith Observability (LangChain auto-trace) ===
# 設了 LANGSMITH_TRACING=true + LANGSMITH_API_KEY 就會自動 trace
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_xxxxxxxxxxxxxxxxxxxxxxxx
# LANGSMITH_PROJECT=marketing-cleaner

# === Bedrock Guardrail (AWS Console 建好才設) ===
# BEDROCK_GUARDRAIL_ID=xxxxxxxx
# BEDROCK_GUARDRAIL_VERSION=1

# === Feature flags ===
# 第一週: true (mock LLM 回傳),等 Bedrock 權限下來改 false
ANALYZER_MOCK_MODE=true
